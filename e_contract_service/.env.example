# Service
SECRET_KEY=replace-with-strong-secret
# Use the same cookie name as the parent Flask app unless you intentionally customize both sides.
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=.example.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# DB
DATABASE_URL=postgresql+psycopg2://econtract:econtract@postgres:5432/econtract

# External integrations (phase2+)
ENABLE_REAL_SIGNING=false
ENABLE_REAL_TIMESTAMP=false
SIGNING_KEY_PEM=
E_KYC_ENDPOINT=
TSA_ENDPOINT=https://freetsa.org/tsr
